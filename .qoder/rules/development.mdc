## Animation Engine

### 1. AnimationPlayer Usage

```typescript
import { AnimationPlayer } from '@algoflow/animation'

const player = new AnimationPlayer({
  steps: [
    { action: 'highlight', target: 0, duration: 500 },
    { action: 'swap', target: [0, 1], duration: 300 },
  ],
  speed: 1,
  autoPlay: false,
})

// Control methods
player.play()
player.pause()
await player.next()
await player.prev()
player.seek(5)
player.setSpeed(2)
player.reset()

// Event listeners
player.on('step', (index) => console.log(`Step ${index}`))
player.on('complete', () => console.log('Animation complete'))
```

### 2. Canvas Rendering Rules

```typescript
// ALWAYS clear before redrawing
function renderFrame() {
  ctx.clearRect(0, 0, width, height)
  
  // Draw background
  drawBackground()
  
  // Draw elements (use incremental updates when possible)
  elements.forEach(el => drawElement(el))
}

// Use requestAnimationFrame for smooth animations
function animate() {
  if (!isAnimating) return
  renderFrame()
  requestAnimationFrame(animate)
}
```

