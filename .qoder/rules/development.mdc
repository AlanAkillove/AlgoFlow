## Component Development

### 1. Visualization Component Interface

All visualization components MUST implement this interface:

```typescript
interface VisualizationProps {
  // Initial data to render
  data: T[]
  
  // Animation steps (optional)
  steps?: AnimationStep[]
  
  // Current step index for external control
  stepIndex?: number
  
  // Styling configuration
  config?: VisualizationConfig
  
  // Event handlers
  onStep?: (index: number) => void
  onComplete?: () => void
}
```

### 2. Canvas Component Pattern

```vue
<script setup lang="ts">
import { ref, onMounted, onUnmounted, watch } from 'vue'
import { useCanvasRenderer } from '@/canvas/useCanvasRenderer'

const canvasRef = ref<HTMLCanvasElement>()
const { render, clear, resize } = useCanvasRenderer(canvasRef)

// Handle resize
const resizeObserver = new ResizeObserver(entries => {
  const { width, height } = entries[0].contentRect
  resize(width, height)
  render()
})

onMounted(() => {
  if (canvasRef.value) {
    resizeObserver.observe(canvasRef.value)
  }
})

onUnmounted(() => {
  resizeObserver.disconnect()
})
</script>

<template>
  <canvas ref="canvasRef" class="viz-canvas" />
</template>
```

### 3. Animation Step Types

```typescript
// Supported action types for all visualizations
type ActionType = 
  | 'highlight'  // Highlight element(s)
  | 'unhighlight' // Remove highlight
  | 'swap'       // Swap two elements (array)
  | 'move'       // Move element to position
  | 'setValue'   // Change element value
  | 'focus'      // Focus/zoom on element
  | 'traverse'   // Traverse edge/path

interface AnimationStep {
  action: ActionType
  target: number | number[]  // Index or indices
  value?: unknown            // New value (for setValue)
  duration: number           // Animation duration in ms
  easing?: string            // Anime.js easing function
  delay?: number             // Delay before animation starts
}
```

