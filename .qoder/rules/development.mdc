## Code Style

### 1. TypeScript Guidelines

```typescript
// ALWAYS use explicit return types for public functions
export function createPlayer(steps: AnimationStep[]): AnimationPlayer { ... }

// Use interfaces for object types (not type aliases for objects)
interface PlayerOptions {
  steps: AnimationStep[]
  speed?: number
}

// Use type for unions, primitives, and computed types
type ActionType = 'highlight' | 'swap' | 'move' | 'setValue'
type StepTarget = number | number[]

// Prefer readonly for immutable data
interface AnimationStep {
  readonly type: ActionType
  readonly target: StepTarget
  duration: number
}

// Use const assertions for literal arrays/objects
const ACTION_TYPES = ['highlight', 'swap', 'move'] as const
```

### 2. Vue Component Guidelines

```vue
<script setup lang="ts">
// Use <script setup> syntax exclusively
import { ref, computed, onMounted, watch } from 'vue'
import type { PropType } from 'vue'

// Define props with TypeScript
interface Props {
  data: number[]
  steps?: AnimationStep[]
  config?: PlayerConfig
}

const props = withDefaults(defineProps<Props>(), {
  steps: () => [],
  config: () => ({ speed: 1 })
})

// Define emits with type-safe event names
const emit = defineEmits<{
  step: [index: number]
  complete: []
  reset: []
}>()

// Use composables for reusable logic
const player = useAnimationPlayer(props.steps)
</script>

<template>
  <!-- Use v-bind shorthand for props -->
  <div :class="classes">
    <slot />
  </div>
</template>

<style scoped>
/* Use scoped styles by default */
.array-viz {
  /* Use CSS variables from theme */
  --bar-color: var(--af-primary, #3b82f6);
}
</style>
```

### 3. File Naming

| Type | Convention | Example |
|------|------------|---------|
| Vue Components | PascalCase.vue | `ArrayViz.vue` |
| TypeScript files | camelCase.ts | `animationPlayer.ts` |
| Type definition files | types.ts | `player/types.ts` |
| Composables | use[Name].ts | `useAnimationPlayer.ts` |
| Test files | *.test.ts | `animationPlayer.test.ts` |
| Constants | UPPER_SNAKE_CASE | `DEFAULT_DURATION` |

