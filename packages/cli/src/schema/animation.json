{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AlgoFlow Animation Schema",
  "description": "Schema for AlgoFlow animation definitions",
  "type": "object",
  "required": ["version", "type", "initialData", "steps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version"
    },
    "type": {
      "type": "string",
      "enum": ["array", "tree", "graph", "stack", "queue", "heap", "bst", "sorting"],
      "description": "Visualization type"
    },
    "initialData": {
      "oneOf": [
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "number" },
              { "type": "string" }
            ]
          },
          "description": "Array/Stack/Queue data"
        },
        {
          "type": "object",
          "description": "Tree/BST data (for tree type)",
          "required": ["value", "id"],
          "properties": {
            "value": { "oneOf": [{ "type": "number" }, { "type": "string" }] },
            "id": { "type": "string" },
            "children": {
              "type": "array",
              "items": { "$ref": "#/properties/initialData/oneOf/1" }
            }
          }
        },
        {
          "type": "object",
          "description": "Graph data (for graph type)",
          "required": ["nodes"],
          "properties": {
            "nodes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "string" },
                  "label": { "oneOf": [{ "type": "number" }, { "type": "string" }] },
                  "x": { "type": "number" },
                  "y": { "type": "number" }
                }
              }
            },
            "edges": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["source", "target"],
                "properties": {
                  "source": { "type": "string" },
                  "target": { "type": "string" },
                  "weight": { "type": "number" },
                  "directed": { "type": "boolean", "default": false }
                }
              }
            }
          }
        }
      ],
      "description": "Initial data for visualization"
    },
    "config": {
      "type": "object",
      "description": "Optional visualization configuration",
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" },
        "speed": { "type": "number", "minimum": 0.1, "maximum": 10 },
        "padding": { "type": "number" },
        "primaryColor": { "type": "string" },
        "highlightColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "textColor": { "type": "string" },
        "showValues": { "type": "boolean", "default": true },
        "showIndices": { "type": "boolean", "default": false },
        "orientation": {
          "type": "string",
          "enum": ["horizontal", "vertical"],
          "default": "vertical"
        },
        "heapType": {
          "type": "string",
          "enum": ["min", "max"],
          "default": "max"
        },
        "circular": {
          "type": "boolean",
          "default": false,
          "description": "For queue: circular queue mode"
        },
        "capacity": {
          "type": "integer",
          "minimum": 1,
          "description": "For circular queue: max capacity"
        },
        "showPointers": {
          "type": "boolean",
          "default": true,
          "description": "For stack/queue: show top/front/rear pointers"
        },
        "nodeRadius": {
          "type": "number",
          "minimum": 10,
          "default": 24,
          "description": "For tree/graph/heap/bst: node radius"
        },
        "itemHeight": {
          "type": "number",
          "minimum": 20,
          "default": 40,
          "description": "For stack: item height"
        },
        "itemWidth": {
          "type": "number",
          "minimum": 40,
          "default": 80,
          "description": "For stack/queue: item width"
        },
        "itemSize": {
          "type": "number",
          "minimum": 20,
          "default": 50,
          "description": "For queue: item size (square)"
        },
        "algorithm": {
          "type": "string",
          "enum": ["bubble", "selection", "insertion", "quick", "merge", "heap"],
          "description": "For sorting: algorithm to use"
        },
        "autoGenerateSteps": {
          "type": "boolean",
          "default": true,
          "description": "For sorting: auto-generate steps from data"
        }
      }
    },
    "steps": {
      "type": "array",
      "description": "Animation steps",
      "items": {
        "type": "object",
        "required": ["action", "target"],
        "properties": {
          "action": {
            "type": "string",
            "enum": [
              "highlight",
              "unhighlight", 
              "swap",
              "move",
              "setValue",
              "focus",
              "traverse",
              "compare",
              "complete",
              "push",
              "pop",
              "enqueue",
              "dequeue",
              "peek",
              "activate",
              "deactivate"
            ],
            "description": "Type of action to perform"
          },
          "target": {
            "oneOf": [
              { "type": "integer", "minimum": 0 },
              { "type": "string" },
              { 
                "type": "array", 
                "items": { 
                  "oneOf": [
                    { "type": "integer", "minimum": 0 },
                    { "type": "string" }
                  ]
                },
                "minItems": 1
              }
            ],
            "description": "Target element index, id, or indices"
          },
          "value": {
            "description": "New value (for setValue, push, enqueue actions)",
            "oneOf": [
              { "type": "number" },
              { "type": "string" },
              { "type": "boolean" }
            ]
          },
          "duration": {
            "type": "number",
            "minimum": 0,
            "default": 300,
            "description": "Animation duration in milliseconds"
          },
          "easing": {
            "type": "string",
            "default": "easeOutQuad",
            "description": "Easing function name"
          },
          "delay": {
            "type": "number",
            "minimum": 0,
            "default": 0,
            "description": "Delay before animation starts"
          },
          "description": {
            "type": "string",
            "description": "Optional description for debugging/display"
          },
          "color": {
            "type": "string",
            "description": "Custom color for highlight action"
          }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "algorithm": { "type": "string" },
        "created": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "complexity": {
          "type": "object",
          "properties": {
            "time": { "type": "string" },
            "space": { "type": "string" }
          }
        }
      }
    }
  }
}
